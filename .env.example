# ─── Phoenix (LLM Tracing) ───────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ─── Celery ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── SAM.gov ─────────────────────────────────────────
SAM_GOV_API_KEY=

# ─── Service URLs (agent service) ────────────────────
BACKEND_URL=http://localhost:8000

# ─── Frontend (Vite) ─────────────────────────────────
