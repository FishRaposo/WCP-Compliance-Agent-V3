# WCP Compliance Agent — Root Environment Quick Reference
#
# Each service has its own .env.example with full documentation:
#   backend/.env.example   — Database, Redis, Elasticsearch, Celery, observability
#   agent/.env.example     — LLM keys, multi-LLM routing, auth, Langfuse
#   frontend/.env.example  — API URL, mock mode
#
# Copy this file to .env and fill in your values, or copy
# the per-service files individually.
#
# ─── PRODUCTION CHECKLIST ───
# Before deploying to production, change these values:
#   LLM_MODE=real              (not mock)
#   AUTH_DISABLED=false         (enable auth)
#   JWT_SECRET=<32+ random>    (not the dev default)
#   VITE_MOCK_API=false         (not true)
#   ENVIRONMENT=production      (not development)

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wcp:wcp@localhost:5432/wcp
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# ─── LLM ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MODE=mock                             # PRODUCTION: change to "real"
LLM_PROVIDER=openai                       # openai | anthropic | ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OLLAMA_BASE_URL=                          # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=dev-secret-change-before-launch-min-32-chars    # PRODUCTION: generate a strong secret
AUTH_DISABLED=true                         # PRODUCTION: change to "false"

# ─── Langfuse (Prompt Infra) ─────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Phoenix (LLM Tracing) ───────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ─── Celery ──────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── External APIs ──────────────────────────────────
SAM_GOV_API_KEY=

# ─── Service URLs ────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ─── Frontend (Vite) ─────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_MOCK_API=true                         # PRODUCTION: change to "false"

# ─── V4 Additions ────────────────────────────────────
# Redis Streams consumer (agent service, V4 real-time events)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Trust score thresholds (both backend and agent read these)
TRUST_SCORE_HIGH_BAND=0.85
TRUST_SCORE_HUMAN_REVIEW_THRESHOLD=0.60
TRUST_SCORE_MEDIUM_BAND=0.60
TRUST_SCORE_REVIEW_THRESHOLD=0.6           # Agent uses this name (alias for TRUST_SCORE_HUMAN_REVIEW_THRESHOLD)

# Backend runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
PHASE=1
SKIP_DB_STARTUP=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Agent runtime
NODE_ENV=development
PORT=3000
