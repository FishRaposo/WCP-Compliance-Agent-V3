# WCP Compliance Agent — Environment Configuration

# OpenAI API key (required for LLM verdict layer)
# Use "mock" or "test-api-key" for offline development/CI
OPENAI_API_KEY=sk-your-key-here

# Optional: Override default OpenAI model
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override default port
# PORT=3000

# Optional: Agent max steps for LLM reasoning (default: 3)
# AGENT_MAX_STEPS=3

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info

# ── Phase 02: PostgreSQL + pgvector (optional) ──
# POSTGRES_URL=postgresql://user:pass@localhost:5432/wcp
# PGVECTOR_DIMENSIONS=1536

# ── Phase 02: Elasticsearch (optional) ──
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_INDEX=dbwd_corpus

# ── Phase 02: Embeddings ──
# EMBEDDING_MODEL=text-embedding-3-small

# ── Feature Flags ──
# FEATURE_PDF_PARSING=true
# FEATURE_RAG_LOOKUP=true
# FEATURE_BATCH_PROCESSING=true
# FEATURE_OBSERVABILITY=true

# ── API Configuration ──
# API_TIMEOUT=30000
# API_MAX_CSV_BYTES=5242880
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── WCP Config Path ──
# WCP_CONFIG_PATH=./wcp.config.json
