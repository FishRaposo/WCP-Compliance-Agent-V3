{
  "name": "wcp-compliance-agent",
  "version": "0.6.0",
  "description": "AI-powered Davis-Bacon Act payroll validation. Checks prevailing wage, overtime, fringe benefits. Three-layer decision pipeline with full audit trail. Open source.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "clean": "node -e \"import('fs').then(fs => { if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true }); });\"",
    "build:backend": "npm run clean --silent && tsc -p tsconfig.backend.json",
    "build:frontend": "vite build",
    "build": "npm run build:backend && npm run build:frontend",
    "dev": "tsx src/server.ts",
    "serve": "node dist/server.js",
    "test": "npm run build && vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:pipeline": "vitest run tests/unit/pipeline-contracts.test.ts tests/unit/trust-score.test.ts tests/integration/decision-pipeline.test.ts",
    "test:calibration": "vitest run tests/eval/trust-calibration.test.ts --reporter=verbose",
    "test:coverage": "vitest run --coverage --exclude tests/eval",
    "test:retrieval": "vitest run tests/unit/hybrid-retriever.test.ts tests/unit/rrf-fusion.test.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "lint:pipeline": "tsx scripts/lint-pipeline-discipline.ts",
    "lint:frontend": "eslint src/frontend --config eslint.config.frontend.js",
    "test:e2e": "playwright test",
    "test:live:smoke": "vitest run --config vitest.config.live.ts tests/live/smoke.test.ts --reporter=verbose",
    "test:live:calibration": "vitest run --config vitest.config.live.ts tests/live/live-calibration.test.ts --reporter=verbose"
  },
  "keywords": [
    "davis-bacon-act",
    "prevailing-wage",
    "federal-compliance",
    "payroll-validation",
    "construction-compliance",
    "wh-347",
    "wage-determination",
    "ai-compliance",
    "automated-audit",
    "trust-scoring",
    "ai-infrastructure",
    "compliance-agent"
  ],
  "author": "FishRaposo",
  "repository": {
    "type": "git",
    "url": "https://github.com/FishRaposo/WCP-Compliance-Agent.git"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^2.0.65",
    "@elastic/elasticsearch": "^9.3.4",
    "@hono/node-server": "^1.19.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/papaparse": "^5.5.2",
    "ai": "^6.0.168",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "hono": "^4.11.0",
    "lucide-react": "^1.8.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.12",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "ts-morph": "^21.0.0",
    "tsx": "^4.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.0.0"
  }
}
