{
  "$schema": "./wcp.config.schema.json",
  "version": "0.6.0",
  "description": "WCP Compliance Agent - Centralized Configuration",

  "pipeline": {
    "deterministic": {
      "extraction": {
        "rolePatterns": [
          "role[:\\s]+(\\w+)",
          "classification[:\\s]+(\\w+)"
        ],
        "hoursPattern": "hours[:\\s]+(\\d+(?:\\.\\d+)?)",
        "wagePattern": "wage[:\\s]+\\$?(\\d+(?:\\.\\d+)?)",
        "fringePattern": "fringe[:\\s]+\\$?(\\d+(?:\\.\\d+)?)"
      },
      "checks": {
        "classification": {
          "enabled": true,
          "severity": "critical",
          "regulation": "29 CFR 5.5(a)(3)(i)",
          "confidenceThreshold": 0.70
        },
        "baseWage": {
          "enabled": true,
          "severity": "critical",
          "regulation": "40 U.S.C. § 3142"
        },
        "overtime": {
          "enabled": true,
          "severity": "high",
          "regulation": "29 CFR 5.32 / CWHSSA",
          "thresholdHours": 40,
          "multiplier": 1.5
        },
        "fringe": {
          "enabled": true,
          "severity": "medium",
          "regulation": "29 CFR 5.5(a)(3)"
        }
      }
    },
    "llm": {
      "model": "gpt-4o-mini",
      "temperature": 0.7,
      "maxTokens": 2000,
      "maxSteps": 3,
      "timeout": 30000,
      "systemPromptPath": "./src/pipeline/reference/instructions/layer2-system-prompt.md"
    },
    "trust": {
      "thresholds": {
        "autoApprove": 0.85,
        "flagForReview": 0.60,
        "requireHuman": 0.60
      },
      "severityImpact": {
        "critical": 0.0,
        "high": 0.5,
        "medium": 0.75,
        "low": 0.9
      }
    }
  },

  "dbwd": {
    "source": "json",
    "corpusPath": "./data/dbwd-corpus.json",
    "effectiveDate": "2024-06-01",
    "geographicScope": "nationwide",
    "phase2Target": {
      "source": "postgresql",
      "schema": "./src/pipeline/reference/values/dbwd-rates.md",
      "tableName": "dbwd_rates"
    }
  },

  "tradeAliases": {
    "Wire Technician": "Electrician",
    "Electrical Technician": "Electrician",
    "Pipe Fitter": "Plumber",
    "Welder": "Ironworker",
    "Cement Finisher": "Concrete Worker",
    "Backhoe Operator": "Operating Engineer"
  },

  "api": {
    "port": 3000,
    "host": "localhost",
    "timeout": 30000,
    "endpoints": {
      "analyze": "/analyze",
      "apiAnalyze": "/api/analyze",
      "health": "/health",
      "apiHealth": "/api/health"
    }
  },

  "features": {
    "pdfParsing": true,
    "ragLookup": true,
    "batchProcessing": true,
    "observability": true
  },

  "observability": {
    "enabled": true,
    "logging": {
      "level": "info",
      "format": "json"
    },
    "tracing": {
      "enabled": false,
      "langfuse": {
        "publicKey": "",
        "secretKey": "",
        "host": "https://cloud.langfuse.com"
      }
    }
  },

  "database": {
    "_note": "Connection URL is read from the POSTGRES_URL environment variable, not from this file.",
    "maxConnections": 10,
    "logging": false
  },

  "humanReview": {
    "enabled": true,
    "persistence": "memory",
    "queuePath": "./data/human-review-queue.json",
    "retentionDays": 365
  },

  "audit": {
    "enabled": true,
    "retentionYears": 7,
    "trail": {
      "layer1": true,
      "layer2": true,
      "layer3": true,
      "humanReview": true
    }
  },

  "mock": {
    "enabled": false,
    "modeDetection": "openaiApiKey",
    "validKeys": [
      "mock",
      "mock-key",
      "test-api-key",
      ""
    ]
  },

  "references": {
    "legislation": "./src/pipeline/reference/legislation/",
    "values": "./src/pipeline/reference/values/",
    "instructions": "./src/pipeline/reference/instructions/"
  }
}
