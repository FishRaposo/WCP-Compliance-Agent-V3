BACKEND_URL=http://localhost:8000
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
NODE_ENV=development

# LLM_MODE controls whether the agent uses real LLM calls or deterministic mocks.
#   mock  = deterministic mock verdicts (development/CI only)
#   real  = actual OpenAI API calls (required for production)
# IMPORTANT: Set to "real" and provide a valid OPENAI_API_KEY before launch.
LLM_MODE=mock

# Multi-LLM Provider Routing (V3.1)
#   openai    = OpenAI GPT-4o (default, required for compliance-critical)
#   anthropic = Anthropic Claude (good for synthesis tasks)
#   ollama    = Local Ollama inference (free, cost mode)
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=                        # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.2

SAM_GOV_API_KEY=                         # Optional: SAM.gov DBWD rate lookups

# Set AUTH_DISABLED=true for local mock-mode E2E curl tests against /api/analyze.
# Keep AUTH_DISABLED=false and use a strong JWT_SECRET for production-like auth testing.
AUTH_DISABLED=false
JWT_SECRET=dev-secret-change-before-launch-min-32-chars

TRUST_SCORE_REVIEW_THRESHOLD=0.60
TRUST_SCORE_HIGH_BAND=0.85

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PORT=3000
CORS_ORIGINS=http://localhost:5173
