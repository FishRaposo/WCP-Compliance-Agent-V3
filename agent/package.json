{
  "name": "wcp-agent",
  "version": "3.0.0",
  "description": "WCP Compliance Agent — TypeScript Integration Layer + Mastra.ai Orchestration",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@mastra/core": "^0.10.0",
    "@ai-sdk/openai": "^1.1.0",
    "ai": "^4.0.0",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "langfuse": "^3.30.0",
    "@arize-ai/phoenix-otel": "^0.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "esbuild": "^0.24.0",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
