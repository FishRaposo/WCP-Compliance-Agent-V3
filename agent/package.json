{
  "name": "wcp-agent",
  "version": "3.0.0",
  "description": "WCP Compliance Agent — TypeScript Integration Layer + Mastra.ai Orchestration",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^1.1.0",
    "@hono/node-server": "^1.13.0",
    "ai": "^4.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.0",
    "langfuse": "^3.30.0",
    "ollama-ai-provider": "^1.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "typescript-eslint": "^8.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
