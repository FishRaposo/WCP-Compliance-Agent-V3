# WCP Compliance Agent - Backend Environment Configuration
# Phase 2: Data Layer + Infrastructure

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://wcp:wcp@localhost:5432/wcp

# =============================================================================
# REDIS (Cache + Celery Broker)
# =============================================================================
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# ELASTICSEARCH
# =============================================================================
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# OBSERVABILITY (Phoenix + Langfuse)
# =============================================================================
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Langfuse configuration (for agent layer)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# AI/LLM
# =============================================================================
OPENAI_API_KEY=                        # Required for Phase 2+ (no mock mode)
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# EXTERNAL APIs
# =============================================================================
SAM_GOV_API_KEY=                       # Optional: SAM.gov wage determination API

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
PHASE=2                                # Current implementation phase
ENVIRONMENT=development                # development | staging | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# CORS origins for frontend
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# =============================================================================
# TRUST SCORE BANDS
# =============================================================================
TRUST_SCORE_HIGH_BAND=0.85
TRUST_SCORE_MEDIUM_BAND=0.60
TRUST_SCORE_HUMAN_REVIEW_THRESHOLD=0.60
