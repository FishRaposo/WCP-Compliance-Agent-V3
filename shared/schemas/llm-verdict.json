{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "llm-verdict",
  "title": "LLMVerdict",
  "description": "Structured output from the Mastra LLM agent after reasoning over deterministic checks",
  "type": "object",
  "required": ["job_id", "verdict", "reasoning", "citations", "confidence"],
  "properties": {
    "job_id": { "type": "string" },
    "verdict": { "type": "string", "enum": ["approved", "rejected", "requires_review"] },
    "reasoning": { "type": "string" },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "regulation": { "type": "string" },
          "section": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "referenced_check_ids": { "type": "array", "items": { "type": "string" } },
    "rag_context_used": { "type": "boolean" },
    "model": { "type": "string" },
    "prompt_version": { "type": "string" },
    "langfuse_trace_id": { "type": "string" },
    "token_usage": {
      "type": "object",
      "properties": {
        "prompt_tokens": { "type": "integer" },
        "completion_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" }
      }
    }
  }
}
